# ENVIRONMENT VARIABLES - Fill in your actual values below

# --- Groq API KEY ---
# Get it for free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# --- TIGERGRAPH CREDENTIALS ---
# Your TigerGraph Cloud host (e.g., https://your-cluster.i.tgcloud.io)
TIGERGRAPH_HOST=your_tigergraph_host_here

# Default TigerGraph username (usually "tigergraph")
TIGERGRAPH_USERNAME=tigergraph

# Your TigerGraph Cloud password
TIGERGRAPH_PASSWORD=your_tigergraph_password_here
TIGERGRAPH_SECRET=your_tigergraph_password_here

# Name of the graph to create/use
TIGERGRAPH_GRAPH_NAME=MyDatabase

# --- HuggingFace Token (for LLM-as-Judge evaluation) ---
# Get it for free at https://huggingface.co/settings/tokens
# Optional — falls back to Groq judge if not set
HF_TOKEN=your_huggingface_token_here
